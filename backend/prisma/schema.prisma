

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expense {
  id             String   @id @default(cuid())
  amount         Decimal  @db.Decimal(12, 2)
  category       String
  description    String
  date           DateTime @db.Date
  idempotencyKey String   @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("expenses")
}